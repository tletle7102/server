# 도메인 — nip.io 사용 (도메인 구입 X)
# EC2 탄력적 IP가 52.79.123.45 라면 → DOMAIN=52.79.123.45.nip.io
# 본인 EIP로 교체
DOMAIN=<EIP>.nip.io

# 호스트 docker 그룹 GID
# 확인: getent group docker | cut -d: -f3
HOST_DOCKER_GID=988

# Postgres
POSTGRES_USER=dbuser
POSTGRES_PASSWORD=

# Jenkins
JENKINS_ADMIN_PASSWORD=
JENKINS_ADMIN_EMAIL=tletle7102@gmail.com

# Traefik dashboard BasicAuth (htpasswd 형식, $는 $$로 이스케이프)
# 생성: htpasswd -nbB admin '비밀번호' | sed -e 's/\$/\$\$/g'
TRAEFIK_DASHBOARD_AUTH=

# sampleapp DB (POSTGRES_PASSWORD와 같은 값 권장)
SAMPLEAPP_DB_USERNAME=dbuser
SAMPLEAPP_DB_PASSWORD=

# Discord webhooks (디스코드 서버에서 채널별 발급)
DISCORD_WEBHOOK_BUILD_SUCCESS=
DISCORD_WEBHOOK_BUILD_FAILURE=
DISCORD_WEBHOOK_DAILY_REPORTS=
DISCORD_WEBHOOK_INFRA_ALERTS=
DISCORD_WEBHOOK_SECURITY=
